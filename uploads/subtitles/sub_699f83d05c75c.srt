415
00:32:24,772 --> 00:32:26,355
‫أتريان أي بندقية؟

416
00:32:27,022 --> 00:32:28,480
‫فُقدت تسع حزم

417
00:32:29,063 --> 00:32:31,855
‫تسعة آلاف دولار من أموالنا اللعينة

418
00:32:31,855 --> 00:32:33,180
‫إنها أموال (سيمون)

419
00:32:34,938 --> 00:32:37,772
‫فليكن دمك للأرض طُهرا يا رفيق!

420
00:32:45,730 --> 00:32:48,605
‫"خدمة (شيكاغو) للتنظيف الاحترافي"

421
00:33:19,063 --> 00:33:19,980
‫حلوتي؟

422
00:33:19,980 --> 00:33:21,605
‫"مرحبا بابا، ماذا تفعل؟"

423
00:33:21,733 --> 00:33:22,855
‫لا شيء

424
00:33:22,927 --> 00:33:23,927
‫أنا...

425
00:33:24,660 --> 00:33:25,730
‫أعمل وحسب

426
00:33:26,413 --> 00:33:27,522
‫أأنت بالمدرسة؟

427
00:33:27,772 --> 00:33:28,605
‫"أجل"

428
00:33:29,522 --> 00:33:31,438
‫وهل يفترض بك مهاتفتي من المدرسة؟

429
00:33:31,813 --> 00:33:32,647
‫"لا"

430
00:33:34,313 --> 00:33:35,600
‫أكل شيء بخير؟

431
00:33:35,647 --> 00:33:37,105
‫"أجل، أردت فقط أن أسلّم عليك"

432
00:33:37,105 --> 00:33:38,230
‫"أحبّك بابا"

433
00:33:38,688 --> 00:33:40,022
‫أحبّك أيضًا

434
00:33:40,022 --> 00:33:40,855
‫"وداعًا"

435
00:33:47,230 --> 00:33:49,147
‫أوَ سيفتح الباب اللعين نفسه؟

436
00:33:50,194 --> 00:33:51,022
‫مكلّخ!

437
00:35:01,097 --> 00:35:01,938
‫ألو الشّاف؟

438
00:35:01,938 --> 00:35:02,855
‫كيف حالك؟

439
00:35:03,855 --> 00:35:05,730
‫حدثت فوضى لعينة

440
00:35:52,230 --> 00:35:53,647
‫ هذا الوضع لا يعجبني

441
00:35:54,105 --> 00:35:56,088
‫أنا بالسّرير بمفردي طيلة الليل

442
00:35:56,797 --> 00:35:57,838
‫كُلْ...

443
00:35:58,463 --> 00:36:00,213
‫وتعال بعدها للفراش هنيهة

444
00:36:13,422 --> 00:36:15,880
‫أتخالين المال يسقط من السّماء؟

445
00:36:22,297 --> 00:36:23,338
‫نذل

446
00:37:07,588 --> 00:37:08,713
‫آمل أنك لا تمانع

447
00:37:12,172 --> 00:37:13,255
‫كنت جائعًا

448
00:37:16,380 --> 00:37:18,047
‫أريد الدردشة معك قليلًا

449
00:37:19,672 --> 00:37:21,088
‫سأخلع الشريط

450
00:37:23,880 --> 00:37:25,693
‫وإن لم تتحكّم بنبرتك...

451
00:37:31,755 --> 00:37:33,088
‫فسأجعلك تسبح

452
00:37:35,255 --> 00:37:36,630
‫أتعلم من أنا؟

453
00:37:37,380 --> 00:37:38,380
‫أعليَّ ذلك؟

454
00:37:38,749 --> 00:37:42,088
‫واضح أنه لا فكرة لديك عمّن تعبث معه

455
00:37:42,797 --> 00:37:44,022
‫تفضل يا كتكوت

456
00:37:44,022 --> 00:37:45,063
‫أخبرني

457
00:37:46,063 --> 00:37:47,530
‫"ﭬﺎريف زاكوني"

458
00:37:47,772 --> 00:37:49,070
‫أسمعت عنّا؟

459
00:37:49,522 --> 00:37:50,463
‫أجل

460
00:37:50,588 --> 00:37:51,672
‫حقًا؟

461
00:37:52,130 --> 00:37:53,355
‫"الأربعة"

462
00:37:53,790 --> 00:37:54,897
‫"آل برادبا"

463
00:37:54,897 --> 00:37:56,022
‫"الإخوة"

464
00:37:56,269 --> 00:37:57,672
‫"دوري اللصوص"

465
00:37:58,213 --> 00:38:01,047
‫أو أيا كان ما تحبّ المافيا
‫الروسية تسمية نفسها هذه الأيام

466
00:38:01,805 --> 00:38:03,342
‫أرى أنك تعرف ماذا تفعل

467
00:38:03,870 --> 00:38:06,105
‫قتلت أعضاء من "الأخوية"

468
00:38:06,105 --> 00:38:07,772
‫وسرقت مالا من "الأخوية"

469
00:38:08,272 --> 00:38:09,897
‫طرأ سوء تفاهم

470
00:38:10,032 --> 00:38:11,974
‫أنا أخ من كبار العصابة

471
00:38:12,480 --> 00:38:15,410
‫أنت وكل من له بك صلة

472
00:38:15,638 --> 00:38:17,813
‫سيذوقون الويل لثلاثة أجيال

473
00:38:17,813 --> 00:38:18,730
‫حسنًا

474
00:38:19,164 --> 00:38:20,247
‫توقعت ذلك

475
00:38:22,380 --> 00:38:24,005
‫نحن نعرف إلى ما ستؤول الأمور

476
00:38:24,884 --> 00:38:25,843
‫إن لم ننهنا بيدنا

477
00:38:25,868 --> 00:38:26,938
‫سير ⁎⁎⁎⁎!

478
00:38:29,647 --> 00:38:31,297
‫هذه لصفعك تلك المرأة هذا الصباح

479
00:38:31,322 --> 00:38:33,030
‫كانت تلك المرأة زوجتي

480
00:38:35,422 --> 00:38:37,172
‫وهذه لصفع زوجتك

481
00:38:44,522 --> 00:38:45,630
‫إليك أموالك

482
00:38:47,047 --> 00:38:48,297
‫ما أنا بلصّ

483
00:38:51,188 --> 00:38:52,588
‫لا شأن لي بأعمالك

484
00:38:53,255 --> 00:38:54,838
‫أنا أبحث عن شابة

485
00:39:00,730 --> 00:39:02,172
‫لست أفهم

486
00:39:02,838 --> 00:39:04,880
‫بالحانة حيث تمارس أعمالك القذرة...

487
00:39:06,255 --> 00:39:08,380
‫اختُطفت فتاة بـ19 من العمر

488
00:39:09,963 --> 00:39:11,022
‫أنا أبحث عنها

489
00:39:24,938 --> 00:39:26,713
‫عليك خفض صوتك

490
00:39:28,297 --> 00:39:29,755
‫ماذا تريد؟

491
00:39:30,223 --> 00:39:31,422
‫أعطني الفتاة

492
00:39:31,983 --> 00:39:33,813
‫وبهذا نعود كلنا لشؤوننا

493
00:39:34,310 --> 00:39:35,380
‫فتاة؟

494
00:39:36,297 --> 00:39:38,463
‫كل هذا لقاء فتاة؟

495
00:39:40,172 --> 00:39:43,755
‫لا أحد يغتال ثلاثة أشخاص لبيع امرأة

496
00:39:44,051 --> 00:39:45,005
‫لا أحد

497
00:39:50,297 --> 00:39:51,547
‫لن أبيعها

498
00:39:52,838 --> 00:39:54,110
‫سآخذها لبيتها

499
00:39:56,228 --> 00:39:58,022
‫لن أتوقّف حتى أفعل ذلك

500
00:40:00,213 --> 00:40:01,338
‫من أنت؟

501
00:40:02,922 --> 00:40:04,005
‫ما أنت؟

502
00:40:05,880 --> 00:40:06,838
‫سير ⁎⁎⁎⁎

503
00:40:07,922 --> 00:40:09,005
‫سير ⁎⁎⁎⁎

504
00:40:10,672 --> 00:40:12,567
‫سير ⁎⁎⁎⁎!

505
00:40:12,567 --> 00:40:13,672
‫سير انت ⁎⁎⁎⁎!

506
00:40:42,197 --> 00:40:43,842
‫" يا ولد الـ⁎⁎⁎⁎..."

507
00:40:44,210 --> 00:40:46,343
‫"(ديمي) أنا سأرميك بقاع البحيرة"

508
00:40:46,494 --> 00:40:48,649
‫" فأنت من جلب هذا لمنزلي"

509
00:40:52,000 --> 00:40:53,000
‫(ديمي)!

510
00:40:55,313 --> 00:40:56,680
‫من أنت يا (ديمي)؟

511
00:41:24,205 --> 00:41:25,380
‫أبي

512
00:41:28,029 --> 00:41:29,230
‫تعازيّ

513
00:41:32,688 --> 00:41:34,350
‫أخذ المال

514
00:41:34,688 --> 00:41:36,130
‫أعاد المال

515
00:41:36,630 --> 00:41:38,213
‫قتل دون خوف

516
00:41:39,130 --> 00:41:41,050
‫السؤال هو لماذا؟

517
00:41:45,613 --> 00:41:46,563
‫(ﭬﻮلو)...

518
00:41:47,011 --> 00:41:49,306
‫كان رجلا محترما وذو شرف

519
00:41:51,213 --> 00:41:54,005
‫لكن ابنه لم يكن قطّ مثلنا

520
00:41:58,880 --> 00:42:01,088
‫ليس (ديمي) رجل أعمال

521
00:42:01,422 --> 00:42:04,463
‫إنه يوثر المتعة على الكدح

522
00:42:06,213 --> 00:42:08,480
‫كان يطعن قلب أبيه...

523
00:42:08,480 --> 00:42:10,505
‫كل يوم لعين

524
00:42:14,172 --> 00:42:15,630
‫جدوا هذا الرجل

525
00:42:20,005 --> 00:42:21,420
‫واجلبوه لي

526
00:42:38,022 --> 00:42:39,640
‫اسمي (جيني غارسيا)

527
00:42:40,346 --> 00:42:41,730
‫والدي هو (جو)

528
00:42:41,855 --> 00:42:43,255
‫والدتي (كارلا)

529
00:42:43,880 --> 00:42:46,172
‫اختطفتم الفتاة الخطأ، هذه غلطة

530
00:42:46,922 --> 00:42:49,880
‫هذا غير صحيح

531
00:42:52,422 --> 00:42:54,630
‫أنت لست حقيقية

532
00:42:55,057 --> 00:42:56,057
‫هذا...

533
00:42:57,355 --> 00:42:59,005
‫هذا هو الشيء الحقيقي

534
00:43:01,111 --> 00:43:02,629
‫كلي طعامك

535
00:43:03,213 --> 00:43:05,513
‫ارتدي هذه الملابس وأطبقي فاهك!

536
00:43:05,538 --> 00:43:06,355
‫سيري ⁎⁎⁎⁎!

537
00:43:08,255 --> 00:43:10,547
‫أشهدتِ موت أحد قبلًا؟

538
00:43:15,755 --> 00:43:19,130
‫يخبو بريق عينيه فورًا

539
00:43:21,172 --> 00:43:23,088
‫كم أنت جميلة!

540
00:43:25,505 --> 00:43:27,297
‫ألستِ كذلك يا أميرة؟

541
00:43:41,172 --> 00:43:42,922
‫كلي طعامك

542
00:44:08,047 --> 00:44:10,713
‫"إدارة مكافحة المخدرات"

543
00:44:17,768 --> 00:44:18,794
‫كيف الحال يا زعيم؟

544
00:44:18,819 --> 00:44:20,147
‫أحصلت على عقود عالية الأجر؟

545
00:44:20,147 --> 00:44:21,130
‫أجل، أجل

546
00:44:21,463 --> 00:44:23,088
‫لكن فقط لصبّ الإسمنت

547
00:44:23,672 --> 00:44:24,880
‫لقد خرجت من اللّعبة

548
00:44:25,130 --> 00:44:26,922
‫بتُّ الآن من دافعي الضرائب

549
00:44:27,963 --> 00:44:29,047
‫"أتحدثت إلى (غوني)؟"

550
00:44:29,072 --> 00:44:30,072
‫"كيف حاله؟"

551
00:44:30,361 --> 00:44:31,563
‫"رأيته أمس"

552
00:44:31,563 --> 00:44:32,750
‫"إنه سعيد"

553
00:44:33,063 --> 00:44:35,551
‫أنت لا تتصّل بي إلّا
‫حين تحتاج معروفا، لذا...

554
00:44:35,761 --> 00:44:36,833
‫ما مرادك؟

555
00:44:36,897 --> 00:44:38,730
‫أبحث عن شخص يدعى (ديمي)

556
00:44:38,876 --> 00:44:40,230
‫أوربّما (ديميتري)

557
00:44:40,230 --> 00:44:41,175
‫"إنه شريك..."

558
00:44:41,175 --> 00:44:43,313
‫(ﭬﻼديمير كاليسنيك)

559
00:44:43,313 --> 00:44:45,272
‫"هذا شخص مهم جدا يا زعيم"

560
00:44:45,297 --> 00:44:46,588
‫إنه من المافيا يا زعيم

561
00:44:47,221 --> 00:44:48,950
‫عضو نافذ بعصابة "آل برادبا"

562
00:44:50,289 --> 00:44:52,088
‫ليس شخصا قد تودّ العبث معه

563
00:44:52,113 --> 00:44:53,605
‫"لا، إطلاقًا"

564
00:44:53,784 --> 00:44:55,022
‫(ديمي) هذا...

565
00:44:55,272 --> 00:44:57,463
‫قد يكون متورطا بتجارة البشر

566
00:44:57,480 --> 00:44:59,438
‫"أيمكنك البحث بقاعدة بيانات
‫المباحث الوطنية ثم مباحث الجريمة؟"

567
00:44:59,438 --> 00:45:01,230
‫"وانظر إن كنت ستحصل على معلومات"

568
00:45:01,230 --> 00:45:02,480
‫عليّ توخي الجذر

569
00:45:02,480 --> 00:45:04,813
‫"لكن ثمّة حانة تسمى
‫(هايتيس) بـ(شولييت)"

570
00:45:04,813 --> 00:45:06,313
‫"حيث يبيعون مخدر الميث مع الروس"

571
00:45:06,313 --> 00:45:07,647
‫اذهب لارتشاف جعة

572
00:45:07,647 --> 00:45:08,480
‫"هذا جيد"

573
00:45:08,480 --> 00:45:09,605
‫"شكرًا"

574
00:45:41,105 --> 00:45:42,563
‫مرحبا، ماذا أجلب لك؟

575
00:45:42,855 --> 00:45:43,897
‫كأس جعة

576
00:45:44,480 --> 00:45:45,605
‫حسب ذوقك

577
00:45:45,855 --> 00:45:46,855
‫حسنًا

578
00:46:09,070 --> 00:46:10,938
‫مرحبا يا غريبة، أين كنت؟

579
00:46:11,688 --> 00:46:12,963
‫أحاول جني المال

580
00:46:13,813 --> 00:46:14,755
‫أتعلمين...

581
00:46:16,338 --> 00:46:19,855
‫يُشاع أنك وأخاك الحقير تحدثتما مع الروس

582
00:46:20,313 --> 00:46:22,075
‫ويُشاع أنك أفرطت بالانتشاء...

583
00:46:22,075 --> 00:46:25,230
‫وقتلت (بيغ مايك) بوَكر دعارة
‫ورميت اللوم على بعض السارقين

584
00:46:25,230 --> 00:46:26,397
‫أغلقي ثغرك!

585
00:46:27,147 --> 00:46:31,110
‫إن علم (دودج) أن أحد أتباعه
‫يتحدث مع الروس، فسيُجنّ جنونه

586
00:46:38,130 --> 00:46:39,255
‫هل تعرف هذا الرجل؟

587
00:46:39,838 --> 00:46:41,397
‫لا، لم أره قبلًا

588
00:46:42,022 --> 00:46:42,938
‫لا يعجبني

589
00:46:43,272 --> 00:46:44,422
‫يبدو شرطيًا

590
00:46:47,005 --> 00:46:49,088
‫لديه سلاح بجيبه

591
00:46:49,630 --> 00:46:51,230
‫يبدو كمسدّس "38"، أتراه؟

592
00:46:51,230 --> 00:46:52,147
‫أجل

593
00:46:52,730 --> 00:46:53,897
‫تحقّق منه يا بنيّ

594
00:47:26,630 --> 00:47:27,713
‫اتبعني

595
00:47:50,963 --> 00:47:52,255
‫تحدّث مع الزعيم

596
00:47:59,088 --> 00:48:00,130
‫أتبحث عن شيء ما؟

597
00:48:00,505 --> 00:48:03,047
‫لي اهتمام بشراء بعض الحلويات يا رفيق

598
00:48:05,020 --> 00:48:06,603
‫فلِم التسلّح إذن يا أخي؟

599
00:48:09,047 --> 00:48:10,213
‫بحوزتي مال

600
00:48:10,922 --> 00:48:12,922
‫ولا يروقني أن يسلبه مني رجل بسكّين

601
00:48:18,797 --> 00:48:19,990
‫إنه شرطيّ

602
00:48:22,588 --> 00:48:23,797
‫أأنت شرطيّ؟

603
00:48:24,380 --> 00:48:25,376
‫لا

604
00:48:25,550 --> 00:48:26,563
‫وأنت؟

605
00:48:30,370 --> 00:48:31,797
‫أخل جيوبك يا أصلع

606
00:48:32,450 --> 00:48:33,990
‫لنر إن كانت ثمّة شارة

607
00:48:34,397 --> 00:48:35,713
‫سمعت الزّعيم

608
00:48:36,255 --> 00:48:37,547
‫ضع كل شيء على الطاولة

609
00:48:37,797 --> 00:48:38,963
‫الآن!

610
00:48:39,922 --> 00:48:42,255
‫لم آت هنا لأُهان

611
00:49:00,922 --> 00:49:02,088
‫حسنًا

612
00:49:05,297 --> 00:49:06,547
‫لنلعب

613
00:49:07,311 --> 00:49:08,231
‫عطيوه!

614
00:49:37,188 --> 00:49:38,510
‫عليك به يا أحي!

615
00:50:07,438 --> 00:50:08,650
‫وداعا يا حلو!

616
00:50:09,563 --> 00:50:10,605
‫كفى!

617
00:50:23,297 --> 00:50:25,755
‫ربّاني جدي على ألّا أصافح أبدا وأنا جالس

618
00:50:29,005 --> 00:50:30,505
‫تأمّل تلك العضلات

619
00:50:30,843 --> 00:50:32,090
‫لست شرطيًا

620
00:50:32,730 --> 00:50:33,938
‫أنت رجل عامل

621
00:50:34,897 --> 00:50:36,810
‫قضيت كل حياتي بالبناء

622
00:50:36,950 --> 00:50:37,950
‫هل كنت جنديًا؟

623
00:50:38,605 --> 00:50:39,930
‫لأنك تقاتل كجندي

624
00:50:39,930 --> 00:50:41,090
‫قضيت نصيبي

625
00:50:41,396 --> 00:50:42,647
‫كنتُ طيارًا

626
00:50:43,397 --> 00:50:45,271
‫درّبونا على القفز من الطائرات

627
00:50:45,295 --> 00:50:46,897
‫وبالأخير أخذونا للمعركة بحافلة

628
00:50:47,897 --> 00:50:48,938
